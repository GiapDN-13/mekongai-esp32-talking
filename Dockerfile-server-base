# Dockerfile-server-base
# Base image with system dependencies and Python packages
FROM python:3.10-slim

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends libopus0 ffmpeg locales && \
    sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen && \
    locale-gen && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Configure pip (use default PyPI; override in data/.config.yaml for custom mirrors)
RUN pip config set global.timeout 120 && \
    pip config set install.retries 5

# Ensure correct character encoding
ENV LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8 \
    PYTHONIOENCODING=utf-8

WORKDIR /opt/xiaozhi-esp32-server

# Copy and install Python dependencies
COPY main/xiaozhi-server/requirements.txt .
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir -r requirements.txt --default-timeout=120 --retries 5
